# Chi Expense — Staging Environment
# Copy to .env and fill in your staging credentials

NODE_ENV=staging
PORT=3000
FRONTEND_URL=http://localhost:8081

# Better Auth
BETTER_AUTH_SECRET=your-staging-auth-secret

# Turso — staging database (separate from production)
TURSO_CONNECTION_URL=libsql://your-project-staging.turso.io
TURSO_AUTH_TOKEN=your-staging-turso-token

# GitHub OAuth (can reuse dev credentials or create separate app)
GITHUB_CLIENT_ID=your-staging-github-client-id
GITHUB_CLIENT_SECRET=your-staging-github-client-secret

# Apple Sign-In (use separate Service ID for staging if available)
APPLE_CLIENT_ID=your-staging-apple-client-id
APPLE_CLIENT_SECRET=your-staging-apple-client-secret
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id

# Redis — staging instance (separate from production)
UPSTASH_REDIS_REST_URL=https://your-staging.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-staging-redis-token

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# Sentry — separate DSN recommended for staging
SENTRY_DSN=https://your-staging-sentry-dsn
